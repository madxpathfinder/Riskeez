# ──────────────────────────────────────────────────────────────────────────────
# Riskeez Enterprise — Backend Environment Variables
# Copy this file to backend/.env and fill in the values.
# The setup.sh script will generate this file automatically.
# ──────────────────────────────────────────────────────────────────────────────

# Port the Express API listens on (Nginx proxies /api/* to this port)
PORT=3001

# Node environment — use 'production' on live servers, 'development' locally
NODE_ENV=production

# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://riskeez_user:YOUR_PASSWORD@localhost:5432/riskeez

# Set to 'true' if your PostgreSQL server requires SSL/TLS connections
# (e.g., managed cloud databases). Leave 'false' for local installs.
DB_SSL=false

# JSON Web Token secret — must be a long, random string (64+ hex chars).
# Generate one with: openssl rand -hex 64
JWT_SECRET=YOUR_64_CHAR_RANDOM_HEX_SECRET

# The origin that the frontend is served from.
# Used for CORS allow-list. Include the protocol and port if non-standard.
# Examples:
#   http://192.168.1.50
#   https://riskeez.example.com
ALLOWED_ORIGIN=http://YOUR_SERVER_IP
