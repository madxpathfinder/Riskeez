# App Configuration
APP_ENV=production
APP_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://riskeez:riskeez_password@postgres:5432/riskeez

# Security
JWT_SECRET=change_this_secret_before_production

# AI Provider Configuration
# Options: gemini, ollama, mock
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
MOCK_AI_FALLBACK_ENABLED=true

# Storage Configuration
# Options: local, s3, supabase
STORAGE_PROVIDER=local
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=riskeez_minio_key
MINIO_SECRET_KEY=riskeez_minio_secret

# Supabase (Optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
