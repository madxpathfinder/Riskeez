# Riskeez Backend Environment Configuration

PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/riskeez

# Security
JWT_SECRET=super-secret-key-change-this-in-production
APP_URL=http://localhost:3000

# AI Services
AI_PROVIDER=gemini # ollama, gemini, openai_compatible
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Storage
STORAGE_PROVIDER=local # local, supabase, s3
STORAGE_PATH=./uploads

# Supabase (Optional)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY= # CRITICAL: NEVER EXPOSE IN FRONTEND

# Security Warning:
# SUPABASE_SERVICE_ROLE_KEY must never be exposed in frontend code.
# It grants full bypass of RLS policies.
